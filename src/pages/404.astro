---
/**
 * DOS-style 404 page — faithful port of web-admin DosNotFoundPage.tsx.
 * Full-viewport CRT terminal with sequential BIOS boot animation.
 */
import "@fontsource-variable/geist-mono";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 – Page not found | homeDNS Docs</title>
    <meta name="description" content="The page you requested could not be found." />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html, body {
        height: 100%;
        overflow: hidden;
        background: #000;
      }

      @keyframes dos-blink {
        0%, 49% { opacity: 1; }
        50%, 100% { opacity: 0; }
      }

      .dos-cursor {
        display: inline-block;
        width: 8px;
        height: 0.85em;
        background: #AAAAAA;
        vertical-align: text-bottom;
        animation: dos-blink 1s step-end infinite;
        margin-left: 1px;
      }

      .dos-scrollarea::-webkit-scrollbar { display: none; }
      .dos-scrollarea { scrollbar-width: none; }

      .dos-backdrop {
        position: fixed;
        inset: 0;
        z-index: 50;
        background: rgba(0, 0, 0, 0.75);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .dos-terminal {
        position: relative;
        width: 75vw;
        height: 75vh;
        background: #000000;
        border: 1px solid #2a2a2a;
        outline: 1px solid #333333;
        outline-offset: 3px;
        box-shadow: 0 0 40px rgba(0, 170, 170, 0.06), 0 30px 60px rgba(0, 0, 0, 0.95);
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }

      .dos-scanlines {
        position: absolute;
        inset: 0;
        pointer-events: none;
        z-index: 2;
        background-image: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 2px,
          rgba(0, 0, 0, 0.055) 2px,
          rgba(0, 0, 0, 0.055) 4px
        );
      }

      .dos-scrollarea {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 16px 18px 22px;
        font-family: 'Geist Mono Variable', 'Geist Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 13px;
        line-height: 1.65;
        position: relative;
        z-index: 1;
      }

      .dos-line {
        min-height: 1.65em;
        white-space: pre;
      }

      .dos-link {
        margin-top: 16px;
      }

      .dos-link a {
        color: #00AAAA;
        font-family: 'Geist Mono Variable', 'Geist Mono', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 13px;
        text-decoration: none;
        border-bottom: 1px solid rgba(0, 170, 170, 0.45);
        text-shadow: 0 0 8px rgba(0, 170, 170, 0.5);
      }

      .dos-link a:hover {
        color: #33DDCC;
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        margin: -1px;
        padding: 0;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
    </style>
  </head>
  <body>
    <div class="dos-backdrop" role="dialog" aria-modal="true" aria-label="Page not found">
      <div class="dos-terminal">
        <div class="dos-scanlines" aria-hidden="true"></div>
        <div class="dos-scrollarea" id="dos-term">
          <h1 class="sr-only">404 – Page not found</h1>
        </div>
      </div>
    </div>

    <script is:inline>
      (function () {
        const FONT = "'Geist Mono Variable', 'Geist Mono', ui-monospace, monospace";
        const P = { gray: "#AAAAAA", yellow: "#FFFF55", white: "#FFFFFF", red: "#FF5555", dim: "#555555" };
        const MEM_COLOR = "#00AAAA";

        const term = document.getElementById("dos-term");
        const pathname = window.location.pathname;
        const cmd = " resolve --route " + pathname;
        const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        let memLine = null;
        let typingLine = null;

        function addLine(text, color) {
          const div = document.createElement("div");
          div.className = "dos-line";
          div.style.color = P[color] || P.gray;
          if (color === "yellow") {
            div.style.textShadow = "0 0 8px rgba(255,255,85,0.3)";
          }
          div.textContent = text || "\u00A0";
          term.appendChild(div);
          term.scrollTop = term.scrollHeight;
        }

        function addMemoryLine() {
          const div = document.createElement("div");
          div.className = "dos-line";
          div.style.color = P.gray;
          div.style.whiteSpace = "pre";
          div.innerHTML = "Memory Test : <span style=\"color:" + MEM_COLOR + "\">0K</span>";
          term.appendChild(div);
          memLine = div;
          term.scrollTop = term.scrollHeight;
        }

        function updateMemory(k) {
          if (!memLine) return;
          const suffix = k >= 640 ? " OK" : "";
          memLine.innerHTML = "Memory Test : <span style=\"color:" + MEM_COLOR + "\">" + k + "K</span>" + suffix;
        }

        function startTypewriter(onDone) {
          const div = document.createElement("div");
          div.className = "dos-line";
          div.style.color = P.white;
          div.style.whiteSpace = "pre";
          term.appendChild(div);
          typingLine = div;

          let i = 0;
          const iv = setInterval(function () {
            i++;
            div.innerHTML = "<span style=\"color:" + P.gray + "\">C:\\HOMEDNS&gt;</span>" +
              escapeHtml(cmd.slice(0, i)) +
              "<span class=\"dos-cursor\"></span>";
            term.scrollTop = term.scrollHeight;
            if (i >= cmd.length) {
              clearInterval(iv);
              if (onDone) onDone();
            }
          }, 35);
          return iv;
        }

        function commitCommand() {
          if (typingLine) {
            typingLine.remove();
            typingLine = null;
          }
          addLine("C:\\HOMEDNS>" + cmd, "white");
          addLine("Bad command or file name", "red");
        }

        function showIdleCursor() {
          addLine("", "gray");
          const div = document.createElement("div");
          div.className = "dos-line";
          div.style.color = P.gray;
          div.style.whiteSpace = "pre";
          div.innerHTML = "C:\\HOMEDNS&gt;<span class=\"dos-cursor\"></span>";
          term.appendChild(div);
          term.scrollTop = term.scrollHeight;
        }

        function showReturnLink() {
          const wrap = document.createElement("div");
          wrap.className = "dos-link";
          const a = document.createElement("a");
          a.href = "/";
          a.textContent = "[\u21B5] Return to home";
          wrap.appendChild(a);
          term.appendChild(wrap);
          term.scrollTop = term.scrollHeight;
        }

        function escapeHtml(s) {
          return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
        }

        // Reduced motion: show everything immediately
        if (reducedMotion) {
          addLine("Award Modular BIOS v4.51PG, An Energy Star Ally");
          addLine("Copyright (C) 1984-98, Award Software, Inc.");
          addLine("");
          addLine("homeDNS ACPI BIOS Revision 1011 Beta 005");
          addLine("");
          addLine("Intel(R) Pentium(R) III/500 Processor");
          addMemoryLine();
          updateMemory(640);
          addLine("");
          addLine('"640K ought to be enough for anybody."', "yellow");
          addLine("                                   -- B. Gates, 1981", "dim");
          addLine("");
          addLine("Award Plug and Play BIOS Extension v1.0A");
          addLine("Initialize Plug and Play Cards...");
          addLine("PNP Init Completed");
          addLine("");
          addLine("Starting MS-DOS...");
          addLine("");
          addLine("HIMEM is testing extended memory...done.");
          addLine("");
          addLine("MS-DOS Version 5.00", "white");
          addLine("(C)Copyright Microsoft Corp 1981-1991");
          addLine("");
          addLine("C:\\HOMEDNS>" + cmd, "white");
          addLine("Bad command or file name", "red");
          addLine("");
          showIdleCursor();
          showReturnLink();
          return;
        }

        // Full animation
        var timers = [];
        var intervals = [];
        var t = 0;

        function after(ms, fn) {
          t += ms;
          timers.push(setTimeout(fn, t));
        }

        // Phase 1: BIOS header
        after(0,   function () { addLine("Award Modular BIOS v4.51PG, An Energy Star Ally"); });
        after(60,  function () { addLine("Copyright (C) 1984-98, Award Software, Inc."); });
        after(80,  function () { addLine(""); });
        after(40,  function () { addLine("homeDNS ACPI BIOS Revision 1011 Beta 005"); });
        after(120, function () { addLine(""); });
        after(40,  function () { addLine("Intel(R) Pentium(R) III/500 Processor"); });

        // Phase 2: Memory test
        after(80, function () {
          addMemoryLine();
          var k = 0;
          var iv = setInterval(function () {
            k = Math.min(k + 32, 640);
            updateMemory(k);
            if (k >= 640) clearInterval(iv);
          }, 12);
          intervals.push(iv);
        });

        // Phase 3: Gates quote
        after(320, function () {
          addLine("");
          addLine('"640K ought to be enough for anybody."', "yellow");
        });
        after(60, function () { addLine("                                   -- B. Gates, 1981", "dim"); });

        // Phase 4: Plug and Play
        after(500, function () {
          addLine("");
          addLine("Award Plug and Play BIOS Extension v1.0A");
        });
        after(50,  function () { addLine("Initialize Plug and Play Cards..."); });
        after(280, function () { addLine("PNP Init Completed"); });

        // Phase 5: DOS boot
        after(600, function () {
          addLine("");
          addLine("Starting MS-DOS...");
        });
        after(420, function () { addLine(""); });
        after(30,  function () { addLine("HIMEM is testing extended memory...done."); });
        after(280, function () { addLine(""); });
        after(60,  function () { addLine("MS-DOS Version 5.00", "white"); });
        after(60,  function () { addLine("(C)Copyright Microsoft Corp 1981-1991"); });
        after(380, function () { addLine(""); });

        // Phase 6: Typewriter command
        after(80, function () {
          var typeIv = startTypewriter(function () {});
          intervals.push(typeIv);
        });

        var typingMs = Math.min(cmd.length * 35, 1800) + 400;
        after(typingMs, function () {
          commitCommand();
        });

        // Phase 7: Done
        after(200, function () { showIdleCursor(); });
        after(400, function () { showReturnLink(); });
      })();
    </script>
  </body>
</html>
