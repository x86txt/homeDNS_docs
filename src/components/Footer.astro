---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="site-footer-left">
      <span class="site-footer-brand">homeDNS</span>
      <span class="site-footer-sep">·</span>
      <span class="site-footer-copy">© {year} homeDNS Project. Open-source, MIT licensed.</span>
    </div>
    <nav class="site-footer-icons" aria-label="Footer links">
      <!-- GitHub -->
      <a
        href="https://github.com/x86txt/homeDNS"
        class="site-footer-icon"
        aria-label="GitHub"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 .3a12 12 0 0 0-3.8 23.38c.6.12.83-.26.83-.57L9 21.07c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.08-.74.09-.73.09-.73 1.2.09 1.83 1.24 1.83 1.24 1.08 1.83 2.81 1.3 3.5 1 .1-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.64 1.66.24 2.88.12 3.18a4.65 4.65 0 0 1 1.23 3.22c0 4.61-2.8 5.63-5.48 5.92.42.36.81 1.1.81 2.22l-.01 3.29c0 .31.2.69.82.57A12 12 0 0 0 12 .3Z" />
        </svg>
      </a>

      <!-- Discussions / Community -->
      <a
        href="https://github.com/x86txt/homeDNS/discussions"
        class="site-footer-icon"
        aria-label="Community discussions"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
        </svg>
      </a>

      <!-- Issues / Bug reports -->
      <a
        href="https://github.com/x86txt/homeDNS/issues"
        class="site-footer-icon"
        aria-label="Report an issue"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10" />
          <line x1="12" y1="8" x2="12" y2="12" />
          <line x1="12" y1="16" x2="12.01" y2="16" />
        </svg>
      </a>

      <!-- Maintainer GitHub profile (same slot as prior contact icon) -->
      <a
        href="https://github.com/x86txt"
        class="site-footer-icon"
        aria-label="x86txt on GitHub"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
      </a>
    </nav>
  </div>
</footer>
